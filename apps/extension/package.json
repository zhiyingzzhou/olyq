{
  "name": "@olyq/extension",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:chromium": "cross-env OLYQ_TARGET=chromium vite",
    "dev:firefox": "cross-env OLYQ_TARGET=firefox vite",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.e2e.json",
    "build:chromium": "cross-env OLYQ_TARGET=chromium vite build && node ./scripts/check-extension-build-output.mjs dist && node ./scripts/check-technology-stack-size-budgets.mjs dist",
    "build:firefox": "cross-env OLYQ_TARGET=firefox vite build && node ./scripts/check-extension-build-output.mjs dist-firefox && node ./scripts/check-technology-stack-size-budgets.mjs dist-firefox",
    "build:test:chromium": "cross-env OLYQ_TARGET=chromium vite build --mode test",
    "build:test:firefox": "cross-env OLYQ_TARGET=firefox vite build --mode test",
    "e2e": "pnpm e2e:mock",
    "e2e:mock": "pnpm build:test:chromium && node ./scripts/run-playwright.mjs test e2e/sidepanel-load.spec.ts e2e/chat-dialog.spec.ts e2e/global-search-jump.spec.ts e2e/page-context-bar.spec.ts e2e/paint-responsive-layout.spec.ts e2e/ui-upgrade-regression.spec.ts e2e/page-tools-host-isolation.spec.ts e2e/markdown-mermaid-upgrade.spec.ts e2e/data-persistence-regression.spec.ts",
    "e2e:live": "pnpm build:test:chromium && node ./scripts/run-playwright.mjs test e2e/providers-live.spec.ts",
    "dependency-upgrade-smoke": "node ./scripts/dependency-upgrade-smoke.mjs",
    "package:chromium": "node ./scripts/package-extension.mjs chromium",
    "package:firefox": "node ./scripts/package-extension.mjs firefox",
    "package:firefox-source": "node ./scripts/package-extension.mjs firefox-source",
    "package:all": "node ./scripts/package-extension.mjs all",
    "verify:node-version": "node ../../scripts/verify-node-version.mjs",
    "prelint": "pnpm verify:node-version",
    "lint": "eslint .",
    "pretypecheck": "pnpm verify:node-version",
    "pretest": "pnpm verify:node-version",
    "test": "vitest run",
    "prebuild:chromium": "pnpm verify:node-version",
    "prebuild:firefox": "pnpm verify:node-version",
    "preverify": "pnpm verify:node-version",
    "benchmark:page-style": "pnpm build:test:chromium && pnpm build:test:firefox && node ./scripts/run-page-style-benchmark.mjs",
    "benchmark:browser-context": "pnpm exec vite-node ./scripts/run-browser-context-benchmark.ts",
    "benchmark:technology-stack": "pnpm exec vite-node ./scripts/run-technology-stack-benchmark.ts",
    "generate:technology-icons": "node ./scripts/generate-technology-icons.mjs",
    "generate:technology-fingerprints": "node ./scripts/generate-technology-fingerprint-bundle.mjs",
    "generate:store-promos": "node ./scripts/generate-store-promos.mjs && node ../../scripts/sync-product-assets.mjs",
    "generate:store-posters": "node ./scripts/generate-store-posters.mjs && node ../../scripts/sync-product-assets.mjs",
    "generate:website-hero": "node ./scripts/generate-website-hero.mjs && node ../../scripts/sync-product-assets.mjs",
    "generate:website-product-screenshots": "node ./scripts/generate-website-product-screenshots.mjs && node ../../scripts/sync-product-assets.mjs",
    "report:technology-stack-coverage": "pnpm exec vite-node ./scripts/report-technology-stack-coverage.ts",
    "report:technology-stack-accuracy": "pnpm build:test:chromium && pnpm exec vite-node ./scripts/run-technology-stack-accuracy.ts",
    "verify:technology-stack-sources": "pnpm exec vite-node ./scripts/verify-technology-stack-source-urls.ts",
    "verify:technology-icons": "node ./scripts/verify-technology-icons.mjs",
    "smoke:technology-stack": "pnpm exec vite-node ./scripts/run-technology-stack-smoke.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build:chromium && pnpm build:firefox"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "4.0.114",
    "@ai-sdk/anthropic": "3.0.82",
    "@ai-sdk/cohere": "3.0.36",
    "@ai-sdk/deepseek": "2.0.35",
    "@ai-sdk/gateway": "3.0.127",
    "@ai-sdk/google": "3.0.80",
    "@ai-sdk/google-vertex": "4.0.143",
    "@ai-sdk/groq": "3.0.39",
    "@ai-sdk/mistral": "3.0.37",
    "@ai-sdk/openai": "3.0.69",
    "@ai-sdk/openai-compatible": "2.0.48",
    "@ai-sdk/provider": "3.0.10",
    "@ai-sdk/provider-utils": "4.0.27",
    "@ai-sdk/xai": "3.0.93",
    "@dnd-kit/collision": "0.4.0",
    "@dnd-kit/dom": "0.4.0",
    "@dnd-kit/react": "0.4.0",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dismissable-layer": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-virtual": "^3.14.2",
    "ai": "6.0.199",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "css-tree": "^3.2.1",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.17.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tokenx": "^1.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.43",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "29.1.1",
    "lovable-tagger": "^1.3.0",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "vite-node": "6.0.0",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
