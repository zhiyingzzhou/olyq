{
  "extends": "./tsconfig.base.json",
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.e2e.json" }
  ],
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*"]
    },
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowJs": true,
    "strictNullChecks": false
  }
}
