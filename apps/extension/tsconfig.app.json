{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["vitest/globals", "chrome"],
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
